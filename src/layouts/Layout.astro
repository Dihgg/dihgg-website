---
import '@/styles/global.css';
import SiteFooter from '@/components/SiteFooter';
import SiteHeader from '@/components/SiteHeader';
import { GTAG_ID } from '@/lib/constants';
import type { Locale } from '@/types';
import { DEFAULT_LOCALE, EN_LOCALE } from '@/i18n/config';
import { translations } from '@/data/translations';
import { getRelativeLocaleUrl } from 'astro:i18n';

type AlternateLink = {
  href: string;
  hreflang: string;
};

type FooterData = {
  currentLocale: Locale;
  ptHref: string;
  enHref: string;
  switcherAriaLabel: string;
  madeWithLabel: string;
};

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
  alternates?: AlternateLink[];
}

const {
  title,
  description = 'Portfolio de Diego Lopes: projetos, experiencia e artigos sobre desenvolvimento.',
  lang = DEFAULT_LOCALE,
  alternates = [],
} = Astro.props as Props;

const locale = lang;
const content = translations[locale];
const homePath = getRelativeLocaleUrl(locale);
const blogPath = getRelativeLocaleUrl(locale, 'blog');
const projectsPath = getRelativeLocaleUrl(locale, locale === EN_LOCALE ? 'projects' : 'projetos');
const ptAlternate = alternates.find((alternate) => alternate.hreflang === DEFAULT_LOCALE)?.href;
const enAlternate = alternates.find((alternate) => alternate.hreflang === EN_LOCALE)?.href;

function getSwitcherHref(href: string | undefined, fallback: string) {
  if (!href) {
    return fallback;
  }

  try {
    const url = new URL(href, Astro.url);
    return `${url.pathname}${url.search}${url.hash}`;
  } catch {
    return href.startsWith('/') ? href : fallback;
  }
}

const header: HeaderProps = {
  brandHref: homePath,
  blogHref: blogPath,
  blogLabel: content.headerBlogLabel,
  contactHref: `${homePath}#contato`,
  contactLabel: content.headerContactLabel,
  projectsHref: projectsPath,
  projectsLabel: content.projectsTitle
};
const footer: FooterData = {
  currentLocale: locale,
  ptHref: getSwitcherHref(ptAlternate, getRelativeLocaleUrl(DEFAULT_LOCALE)),
  enHref: getSwitcherHref(enAlternate, getRelativeLocaleUrl(EN_LOCALE)),
  switcherAriaLabel: content.switcherAriaLabel,
  madeWithLabel: content.madeWithLabel
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="/favicon/apple-touch-icon-152x152.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/favicon/safari-pinned-tab.svg" color="#1d4ed8" />
    <meta name="theme-color" content="#1d4ed8" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {alternates.map((alternate) => <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />)}
    {GTAG_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GTAG_ID}`}></script>
        <script is:inline define:vars={{ GTAG_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          gtag('js', new Date());
          gtag('config', GTAG_ID);
        </script>
      </>
    )}
    <title>{title}</title>
  </head>
  <body>
    <SiteHeader {...header} />
    <slot />
    <SiteFooter {...footer} />
  </body>
</html>
