---
import Base from "@/layouts/Base.layout.astro";

import Pill from "@/components/Pill";
import SkillList from "@/components/SkillList";
import SocialLinks from "@/components/SocialLinks";
import ProjectCards from "@/components/ProjectCards";
import WorkCards from "@/components/WorkCards";
import BlogPostsCarousel from "@/components/BlogPostsCarousel";
import { getRelativeLocaleUrl } from "astro:i18n";
import { socialLinks } from "@/data/portfolio";
import Logo from "@/components/Logo";
import Icon from "@/components/Icon";
import { translations } from "@/data/translations";
import { getBlogPosts } from "@/lib/blog";
import { getBlogPostPath } from "@/lib/blog";
import { LATEST_POSTS_COUNT, LATEST_PROJECTS_COUNT } from "@/lib/constants";
import { getWorkItems, getSkills, getProjects } from "@/lib/portfolio";
import { replaceTokens } from "@/lib/utils";
import type { Locale } from "@/types";
import { EN_LOCALE } from "@/i18n/config";

import "@styles/pages/homepage.css";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = translations[locale];
const blogPath = getRelativeLocaleUrl(locale, "blog");
const projectsPath = getRelativeLocaleUrl(
  locale,
  locale === EN_LOCALE ? "projects" : "projetos",
);
const workItems = await getWorkItems(locale);
const skillItems = await getSkills();
const projects = await getProjects(locale);
const projectItems = projects.slice(0, LATEST_PROJECTS_COUNT);
const posts = await getBlogPosts(locale);
const latestPosts = posts.slice(0, LATEST_POSTS_COUNT);

// Transform data to match component expectations
const skillNames = skillItems.map((item) => item.data.name);
const postsWithHref = latestPosts.map((post) => ({
  ...post,
  href: getBlogPostPath(post),
}));
---

<Base
  title={content.homeTitle}
  description={content.homeDescription}
  lang={locale}
  alternates={[
    { href: getRelativeLocaleUrl(locale), hreflang: locale },
    { href: getRelativeLocaleUrl(EN_LOCALE), hreflang: EN_LOCALE }
  ]}
>
  <main id="homepage" class="relative overflow-hidden">
  <div class="hero-glow hero-glow__left"></div>
  <div class="hero-glow hero-glow__right"></div>

  <section class="mx-auto max-w-6xl px-6 pb-16 pt-14 md:pt-20">
    <div class="grid items-center gap-8 md:grid-cols-2">
      <div class="home-hero">
        <Logo className="text-slate-600" />
        <h1 class="home-hero__title">Diego Lopes</h1>
        <p class="home-hero__description">
          {content.heroDescription}
        </p>
        <SocialLinks
          links={socialLinks}
          aria-label={content.socialAriaLabel}
          className="mt-8"
        />
        <div class="flex md:hidden items-center justify-center mt-10">
          <div class="sprite-animation"></div>
        </div>

        <div class="justify-center md:justify-start mt-10 flex flex-wrap gap-2">
          <Pill href={blogPath} icon="book-dead" background>{content.blogCta}</Pill>
          <Pill href={projectsPath} icon="computer" background>{content.projectsTitle}</Pill>
          <Pill variant="primary" href="#contato" icon="mail">{content.contactCta}</Pill>
        </div>
      </div>

      <div class="hidden md:flex items-center justify-center">
        <div class="sprite-animation"></div>
      </div>
    </div>
  </section>

  <section id="sobre" class="home-section">
    <h2 class="section-title">{content.aboutTitle}</h2>
    <p class="mt-8 text-lg text-slate-700">{content.aboutText}</p>
  </section>

  <section id="latest-posts" class="home-section home-section--carousel">
    <div class="home-section__content">
      <h2 class="section-title">{content.latestPostsTitle}</h2>
      <a
        href={blogPath}
        class="read-more-link"
        data-ga="blog-home"
      >
        <span class="underline">{replaceTokens(content.latestPostsCta, { x: posts.length })}</span>
        <Icon name="book-dead" />
      </a>
    </div>
    {
      postsWithHref.length === 0 && (
        <p class="mt-6 rounded-xl border border-blue-100 bg-white/80 p-5 text-slate-600">
          {content.latestPostsEmptyLabel}
        </p>
      )
    }
    {
      postsWithHref.length > 0 && (
        <div class="mt-6 home-section__carousel-wrapper">
          <BlogPostsCarousel
            client:only="react"
            posts={postsWithHref}
            locale={locale}
            ctaLabel={content.latestPostsCardCta}
            goToSlideLabel={content.carouselGoToSlide}
          />
        </div>
      )
    }
  </section>

  <section id="skills" class="home-section">
    <h2 class="section-title">{content.skillsTitle}</h2>
    <SkillList skills={skillNames} className="home-section__content--skills" />
  </section>

  <section id="trabalho" class="home-section">
    <h2 class="section-title">{content.workTitle}</h2>
    <WorkCards items={workItems} />
  </section>

  <section id="projetos" class="home-section">
    <div class="home-section__content">
      <h2 class="section-title">{content.projectsTitle}</h2>
      <a
        href={projectsPath}
        class="read-more-link"
        data-ga="projects-home"
      >
        <span class="underline">{replaceTokens(content.latestProjectsCta, { x: projects.length })}</span>
        <Icon name="computer" />
      </a>
      <ProjectCards
        projects={projectItems}
        classNames={["mt-8"]}
        projectsFilterLabel={content.projectsFilterLabel}
        loadMoreLabel={content.projectsLoadMoreLabel}
      />
    </div>
  </section>

  <section id="contato" class="home-section py-16">
    <h2 class="section-title">{content.contactTitle}</h2>
    <p class="mt-4 text-slate-700">
      {content.contactLead}
      <a
        class="email-link"
        href="mailto:dihgg@dihgg.com"
      >
        dihgg@dihgg.com
      </a>
      .
    </p>
    <SocialLinks
      links={socialLinks}
      aria-label={content.socialAriaLabel}
      className="mt-8"
    />
  </section>
</main>
</Base>
