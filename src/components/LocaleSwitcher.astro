---
import classnames from "classnames";
import type { Locale } from "@/data/siteContent";

interface Props {
  currentLocale: Locale;
  ptHref: string;
  enHref: string;
  ariaLabel: string;
}

const { currentLocale, ptHref, enHref, ariaLabel } = Astro.props;

const classess = (locale: "en" | "pt-BR") =>
  classnames(
    "inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] transition",
    {
      "border-transparent bg-[var(--accent)] text-white":
        currentLocale === locale,
      "border-blue-200 bg-white/80 text-slate-700 hover:bg-blue-50":
        currentLocale !== locale,
    },
  );
---

<nav aria-label={ariaLabel} class="flex items-center gap-2">
  <a href={ptHref} class={classess("pt-BR")}>PT</a>
  <a href={enHref} class={classess("en")}>EN</a>
</nav>
