---
interface Props {
  placeholder?: string;
}

const { placeholder = 'Search...' } = Astro.props;
---

<div id="blog-search-wrap" class="mt-8">
  <div class="blog-search">
    <div id="blog-search"></div>
  </div>
</div>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

<script is:inline define:vars={{ placeholder }}>
  (async function () {
    try {
      await import('/pagefind/pagefind-ui.js');
      const PagefindUI = window.PagefindUI;
      if (typeof PagefindUI !== 'function') {
        throw new Error('PagefindUI constructor is not available on window');
      }

      new PagefindUI({
        element: '#blog-search',
        showImages: false,
        showSubResults: false,
        resetStyles: false,
        showFilters: false,
        placeholder,
      });
    } catch (e) {
      // pagefind index not available (e.g. dev mode before build)
      console.warn('Pagefind not available:', e);
    }
  })();
</script>

