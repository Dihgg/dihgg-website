---
import Layout from '@/layouts/Layout.astro';
import BlogPostCard from '@/components/BlogPostCard';
import BlogSearch from '@/components/pages/BlogSearch.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { translations } from '@/data/translations';
import type { BlogPost, Locale } from '@/types';
import classNames from 'classnames';

interface Props {
  locale: Locale;
  posts: BlogPost[];
  currentPage: number;
  lastPage: number;
  ptHref: string;
  enHref: string;
}

const { locale, posts, currentPage, lastPage, ptHref, enHref } = Astro.props;

const content = translations[locale];

const blogPath = getRelativeLocaleUrl(locale, 'blog');
const homePath = getRelativeLocaleUrl(locale);

const pageTitle = currentPage > 1 ? `${content.blogPageTitle} | ${currentPage}` : content.blogPageTitle;

const pagePaths = (new Array(lastPage)).fill(null).map((_, index) =>
  getRelativeLocaleUrl(locale, index > 0 ? `blog/page/${index + 1}` : 'blog')
);

const previousHref = currentPage > 1 ? pagePaths[currentPage - 2] : null;
const nextHref = currentPage < lastPage ? pagePaths[currentPage] : null;
---

<Layout
  title={pageTitle}
  description={content.blogDescription}
  lang={locale}
  alternates={[
    { href: `${ptHref}`, hreflang: 'pt-BR' },
    { href: `${enHref}`, hreflang: 'en' }
  ]}
  header={{
    brandHref: homePath,
    blogHref: blogPath,
    contactHref: `${homePath}#contato`,
    blogLabel: content.headerBlogLabel,
    contactLabel: content.headerContactLabel
  }}
  footer={{
    currentLocale: locale,
    ptHref,
    enHref,
    switcherAriaLabel: content.switcherAriaLabel,
    madeWithLabel: content.madeWithLabel
  }}
>
  <main class="page-shell page-shell--wide blog-index">
    <a href={homePath} class="page-shell__back-link">{content.backHomeLabel}</a>
    <h1 class="blog-index__title">Blog</h1>
    <p class="blog-index__intro">{content.blogIntro}</p>

    <BlogSearch placeholder={content.searchPlaceholder} />

    {posts.length === 0 ? (
      <p class="blog-index__empty">{content.noPostsLabel}</p>
    ) : (
      <>
        <ul class="blog-index__list">
          {posts.map((post) => (
            <BlogPostCard
              post={post}
              locale={locale}
              ctaLabel={content.latestPostsCardCta}
              variant="horizontal"
            />
          ))}
        </ul>

        {lastPage > 1 && (
          <nav class="blog-pagination" aria-label={content.paginationAriaLabel}>
            <div class="blog-pagination__summary">{currentPage} / {lastPage}</div>

            <div class="blog-pagination__links">
              {previousHref && (
                <a href={previousHref} class="blog-pagination__link blog-pagination__link--direction">
                  {content.paginationPreviousLabel}
                </a>
              )}

              <ol class="blog-pagination__list">
                {pagePaths.map((pagePath, index) => (
                  <li>
                    <a
                      href={pagePath}
                      class={classNames(
                        'blog-pagination__link',
                        {
                          'blog-pagination__link--active': index + 1 === currentPage
                        }
                      )}
                      aria-current={index + 1 === currentPage ? 'page' : undefined}
                    >
                      {index + 1}
                    </a>
                  </li>
                ))}
              </ol>

              {nextHref && (
                <a href={nextHref} class="blog-pagination__link blog-pagination__link--direction">
                  {content.paginationNextLabel}
                </a>
              )}
            </div>
          </nav>
        )}
      </>
    )}
  </main>
</Layout>