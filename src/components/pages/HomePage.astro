---
import Pill from '@/components/Pill';
import BlogPostCard from '@/components/BlogPostCard.astro';
import SkillList from '@/components/SkillList';
import SocialLinks from '@/components/SocialLinks';
import ProjectCards from '@/components/ProjectCards';
import WorkCards from '@/components/WorkCards.astro';
import { socialLinks } from '@/data/portfolio';
import {
  getLocalizedBlogPath,
  siteContent,
  type Locale
} from '@/data/siteContent';
import { getBlogPosts } from '@/lib/blog';
import { LATEST_POSTS_COUNT } from '@/lib/constants';
import { getWorkItems, getSkills, getProjects } from '@/lib/portfolio';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = siteContent[locale];
const workItems = await getWorkItems(locale);
const skillItems = await getSkills();
const projectItems = await getProjects(locale);
const latestPosts = (await getBlogPosts(locale)).slice(0, LATEST_POSTS_COUNT);

// Transform data to match component expectations
const skillNames = skillItems.map(item => item.data.name);
const projects = projectItems.map(item => ({
  name: item.data.name,
  description: item.data.description,
  stack: item.data.stack,
  href: item.data.href
}));
---

<main class="relative overflow-hidden">
  <div class="hero-glow hero-glow-left"></div>
  <div class="hero-glow hero-glow-right"></div>

  <section class="mx-auto max-w-6xl px-6 pb-16 pt-14 md:pt-20">
    <div class="grid items-center gap-8 md:grid-cols-2">
      <div>
        <div class="flex items-center gap-2">
          <img src="/avatar.png" alt="Dihgg avatar" class="h-6 w-6 object-cover" />
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-slate-600">{'{Dihgg}'}</p>
        </div>

        <h1 class="home-hero__title mt-4 max-w-3xl text-5xl font-bold leading-[0.95] md:text-7xl">Diego Lopes</h1>
        <p class="mt-4 max-w-2xl text-lg text-slate-700 md:text-xl">{content.heroLead}</p>

        <div class="mt-8">
          <SocialLinks links={socialLinks} ariaLabel={content.socialAriaLabel} />
        </div>

        <div class="mt-10 flex flex-wrap gap-3">
          <Pill label={content.contactCta} variant="primary" href="#contato" />
          <Pill label={content.blogCta} href={getLocalizedBlogPath(locale)} />
        </div>
      </div>

      <div class="flex items-center justify-center">
        <div class="sprite-animation"></div>
      </div>
    </div>
  </section>

  <section id="sobre" class="mx-auto max-w-6xl px-6 py-12">
    <h2 class="section-title">{content.aboutTitle}</h2>
    <p class="mt-8 max-w-3xl text-lg text-slate-700">{content.aboutText}</p>
  </section>

  <section id="latest-posts" class="mx-auto max-w-6xl px-6 py-12">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <h2 class="section-title">{content.latestPostsTitle}</h2>
      <a
        href={getLocalizedBlogPath(locale)}
        class="text-sm font-semibold text-blue-700 underline decoration-blue-400 decoration-2 underline-offset-4 transition hover:text-blue-900"
      >
        {content.latestPostsCta}
      </a>
    </div>

    {latestPosts.length === 0 ? (
      <p class="mt-6 rounded-xl border border-blue-100 bg-white/80 p-5 text-slate-600">{content.latestPostsEmptyLabel}</p>
    ) : (
      <ul class="mt-6 grid gap-4 md:grid-cols-3">
        {latestPosts.map((post) => (
          <BlogPostCard post={post} locale={locale} ctaLabel={content.latestPostsCardCta} />
        ))}
      </ul>
    )}
  </section>

  <section id="skills" class="mx-auto max-w-6xl px-6 py-12">
    <h2 class="section-title">{content.skillsTitle}</h2>
    <div class="mt-6">
      <SkillList skills={skillNames} />
    </div>
  </section>

  <section id="trabalho" class="mx-auto max-w-6xl px-6 py-12">
    <h2 class="section-title">{content.workTitle}</h2>
    <WorkCards items={workItems} />
  </section>

  <section id="projetos" class="mx-auto max-w-6xl px-6 py-12">
    <h2 class="section-title">{content.projectsTitle}</h2>
    <div class="mt-8">
      <ProjectCards projects={projects} ctaLabel={content.projectCta} />
    </div>
  </section>

  <section id="contato" class="mx-auto max-w-6xl px-6 py-16">
    <h2 class="section-title">{content.contactTitle}</h2>
    <p class="mt-4 text-slate-700">
      {content.contactLead}
      <a
        class="ml-1 underline decoration-blue-500 decoration-2 transition-colors hover:text-blue-600"
        href="mailto:dihgg@outlook.com"
      >
        dihgg@outlook.com
      </a>
      .
    </p>
    <div class="mt-6">
      <SocialLinks links={socialLinks} ariaLabel={content.socialAriaLabel} />
    </div>
  </section>
</main>