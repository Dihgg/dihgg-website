---
import { render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { getLocalizedBlogPath, getLocalizedHomePath, siteContent, type Locale } from '@/data/siteContent';
import { getBlogPostPath, type BlogPost } from '@/lib/blog';
import { formatPostDate } from '@/lib/date';

interface Props {
  locale: Locale;
  post: BlogPost;
  alternatePost: BlogPost | null;
}

const { locale, post, alternatePost } = Astro.props;
const content = siteContent[locale];
const { Content } = await render(post);

const isEnglish = locale === 'en';
const currentPostPath = getBlogPostPath(post);
const fallbackAlternatePath = getLocalizedBlogPath(isEnglish ? 'pt-BR' : 'en');
const alternatePostPath = alternatePost ? getBlogPostPath(alternatePost) : fallbackAlternatePath;

const ptPostPath = isEnglish ? alternatePostPath : currentPostPath;
const enPostPath = isEnglish ? currentPostPath : alternatePostPath;
---

<Layout
  title={`${post.data.title} | Blog Dihgg`}
  description={post.data.description}
  lang={locale}
  alternates={[
    { href: `https://dihgg.com${ptPostPath}`, hreflang: 'pt-BR' },
    { href: `https://dihgg.com${enPostPath}`, hreflang: 'en' }
  ]}
  header={{
    brandHref: isEnglish ? '/en/' : '/',
    blogHref: isEnglish ? '/en/blog/' : '/blog/',
    contactHref: isEnglish ? '/en/#contato' : '/#contato',
    blogLabel: content.headerBlogLabel,
    contactLabel: content.headerContactLabel
  }}
  footer={{
    currentLocale: locale,
    ptHref: ptPostPath,
    enHref: enPostPath,
    switcherAriaLabel: content.switcherAriaLabel,
    madeWithLabel: content.madeWithLabel
  }}
>
  <main class="page-shell page-shell--narrow blog-post">
    <a href={getLocalizedBlogPath(locale)} class="page-shell__back-link">{content.backBlogLabel}</a>

    <h1 data-pagefind-meta="title" class="blog-post__title">{post.data.title}</h1>
    <time
      datetime={post.data.date.toISOString().slice(0, 10)}
      class="blog-post__meta"
    >
      {formatPostDate(post.data.date, locale)}
    </time>

    {post.data.tags.length > 0 && (
      <div class="blog-post__tags">
        {post.data.tags.map((tag) => (
          <span class="blog-post__tag">
            {tag}
          </span>
        ))}
      </div>
    )}

    {post.data.featuredImage && (
      <img
        src={post.data.featuredImage}
        alt={post.data.featuredImageAlt ?? post.data.title}
        class="blog-post__image"
        loading="eager"
      />
    )}

    <article data-blog-content data-pagefind-body data-pagefind-filter={`language:${locale}`} class="blog-post__article prose">
      {post.data.tags.map((tag) => (
        <span class="hidden" data-pagefind-filter={`tag:${tag}`}>{tag}</span>
      ))}
      <Content />
    </article>

    <script is:inline>
      {
        (() => {
          const root = document.querySelector('[data-blog-content]');
          if (!root) return;

          root.querySelectorAll('a[href]').forEach((link) => {
            link.setAttribute('target', '_blank');
            link.setAttribute('rel', 'noopener noreferrer');
          });
        })();
      }
    </script>

    <p class="page-shell__return-link">
      <a href={getLocalizedHomePath(locale)} class="page-shell__return-link-anchor">{content.backHomeLabel}</a>
    </p>
  </main>
</Layout>