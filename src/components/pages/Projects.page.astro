---
import { getProjects } from "@/lib/portfolio";
import { translations } from "@/data/translations";
import { DEFAULT_LOCALE } from "@/i18n/config";
import ProjectCards from "@/components/ProjectCards";
import type { Locale } from "@/types";

interface Props {
    locale: Locale;
}

const { locale } = Astro.props as Props;

const content = translations[locale ?? DEFAULT_LOCALE];
const projects = await getProjects(locale);
---
<main class="page-shell page-shell--wide blog-index">
    <h1 class="page__title">{content.projectsTitle}</h1>
    <p class="page__intro">{content.projectsIntro}</p>
    <ProjectCards
        projects={projects}
        classnames={["blog-index__list", "project-cards--wide"]}
    />
</main>