---
interface Props {
  brandHref: string;
  blogHref: string;
  contactHref: string;
  blogLabel: string;
  contactLabel: string;
}

const {
  brandHref,
  blogHref,
  contactHref,
  blogLabel,
  contactLabel
} = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-blue-100/80 bg-white/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-3">
    <a href={brandHref} class="inline-flex items-center gap-2 text-slate-900 transition hover:text-blue-700">
      <img src="/images/avatar.png" alt="Dihgg icon" class="h-6 w-6 rounded-sm object-cover" />
      <span class="font-mono text-xs uppercase tracking-[0.2em]">{'{Dihgg}'}</span>
    </a>

    <nav class="flex items-center gap-2" aria-label="Main navigation">
      <a
        href={blogHref}
        class="rounded-full border border-blue-100 bg-white/90 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-blue-50 hover:text-blue-700"
      >
        {blogLabel}
      </a>
      <a
        href={contactHref}
        class="rounded-full bg-(--accent) px-4 py-2 text-sm font-semibold text-white transition hover:brightness-110"
      >
        {contactLabel}
      </a>
    </nav>
  </div>
</header>