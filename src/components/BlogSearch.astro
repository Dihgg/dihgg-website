---
interface Props {
  language: 'pt-BR' | 'en';
  placeholder?: string;
}

const { language, placeholder = 'Search...' } = Astro.props;
---

<div id="blog-search-wrap" class="mt-8">
  <div id="blog-search"></div>
</div>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

<script is:inline define:vars={{ language, placeholder }}>
  (async function () {
    try {
      await import('/pagefind/pagefind-ui.js');
      const PagefindUI = window.PagefindUI;
      if (typeof PagefindUI !== 'function') {
        throw new Error('PagefindUI constructor is not available on window');
      }

      new PagefindUI({
        element: '#blog-search',
        showImages: false,
        showSubResults: false,
        resetStyles: false,
        showFilters: false,
        placeholder,
      });
    } catch (e) {
      // pagefind index not available (e.g. dev mode before build)
      console.warn('Pagefind not available:', e);
    }
  })();
</script>

<style is:global>
  .pagefind-ui {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.75rem;
    --pagefind-ui-border: #e2e8f0;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-text: #1e293b;
    --pagefind-ui-font: inherit;
    --pagefind-ui-primary: #2563eb;
    --pagefind-ui-tag-background: #eff6ff;
    --pagefind-ui-tag-border: #bfdbfe;
  }

  .pagefind-ui .pagefind-ui__search-input {
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    padding: 0.625rem 1rem;
    width: 100%;
    font-size: 0.9rem;
    background: #fff;
    color: #1e293b;
    outline: none;
    transition: border-color 0.15s;
  }

  .pagefind-ui .pagefind-ui__search-input:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .pagefind-ui .pagefind-ui__results {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pagefind-ui .pagefind-ui__result {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    transition: border-color 0.15s;
  }

  .pagefind-ui .pagefind-ui__result:hover {
    border-color: #2563eb;
  }

  .pagefind-ui .pagefind-ui__result-title {
    font-weight: 600;
    color: #1e293b;
    text-decoration: none;
  }

  .pagefind-ui .pagefind-ui__result-title:hover {
    color: #2563eb;
  }

  .pagefind-ui .pagefind-ui__result-excerpt {
    font-size: 0.85rem;
    color: #64748b;
    margin-top: 0.25rem;
  }

  .pagefind-ui mark {
    background: #fef9c3;
    color: inherit;
    border-radius: 2px;
    padding: 0 2px;
  }

  .pagefind-ui .pagefind-ui__search-clear {
    background: none;
    border: none;
    cursor: pointer;
    color: #94a3b8;
    padding: 0;
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
  }

  .pagefind-ui .pagefind-ui__form {
    position: relative;
    display: flex;
    align-items: center;
  }

  .pagefind-ui .pagefind-ui__message {
    font-size: 0.85rem;
    color: #64748b;
    margin-top: 0.5rem;
  }

  .pagefind-ui .pagefind-ui__button {
    margin-top: 0.75rem;
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 0.5rem;
    color: #2563eb;
    font-size: 0.85rem;
    padding: 0.4rem 0.85rem;
    cursor: pointer;
    transition: background 0.15s;
  }

  .pagefind-ui .pagefind-ui__button:hover {
    background: #dbeafe;
  }
</style>
