---
import classnames from 'classnames';
import Pill from '@/components/Pill';
import { getBlogPostPath, type BlogPost } from '@/lib/blog';
import { formatPostDate } from '@/lib/date';
import type { Locale } from '@/data/siteContent';

interface Props {
  post: BlogPost;
  locale: Locale;
  ctaLabel: string;
  variant?: 'vertical' | 'horizontal';
}

const {
  post,
  locale,
  ctaLabel,
  variant = 'vertical'
} = Astro.props;

const href = getBlogPostPath(post);

const cardClassName = classnames('blog-card', {
  'blog-card--vertical': variant === 'vertical',
  'blog-card--horizontal': variant === 'horizontal'
});

const titleClassName = classnames('blog-card__title', {
  'blog-card__title--horizontal': variant === 'horizontal',
  'blog-card__title--vertical': variant === 'vertical'
});
---

<li class={cardClassName}>
  <div class="blog-card__layout">
    {post.data.featuredImage && (
      <img
        src={post.data.featuredImage}
        alt={post.data.featuredImageAlt ?? post.data.title}
        class="blog-card__image"
        loading="lazy"
      />
    )}

    <div class="blog-card__content">
      <time datetime={post.data.date.toISOString().slice(0, 10)} class="blog-card__date">{formatPostDate(post.data.date, locale)}</time>
      <a class={titleClassName} href={href}>
        {post.data.title}
      </a>
      <p class="blog-card__description">{post.data.description}</p>
      <div class="blog-card__cta">
        <Pill label={ctaLabel} href={href} />
      </div>
    </div>
  </div>
</li>