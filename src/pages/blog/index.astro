---
import BlogIndexPage from '@/components/pages/BlogIndexPage.astro';
import { getBlogPageCount, getBlogPosts, getLocalizedBlogIndexHrefs, BLOG_POSTS_PER_PAGE } from '@/lib/blog';

const posts = await getBlogPosts('pt-BR');
const alternatePosts = await getBlogPosts('en');
const currentPage = 1;
const alternatePageCount = getBlogPageCount(alternatePosts.length);
const { ptHref, enHref } = getLocalizedBlogIndexHrefs('pt-BR', currentPage, alternatePageCount);
---

<BlogIndexPage
	locale="pt-BR"
	posts={posts.slice(0, BLOG_POSTS_PER_PAGE)}
	currentPage={currentPage}
	lastPage={getBlogPageCount(posts.length)}
	ptHref={ptHref}
	enHref={enHref}
/>
