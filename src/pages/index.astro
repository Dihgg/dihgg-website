---
import Layout from '../layouts/Layout.astro';
import Pill from '../components/Pill';
import SkillList from '../components/SkillList';
import SocialLinks from '../components/SocialLinks';
import ProjectCards from '../components/ProjectCards';
import { projects, skills, socialLinks, timeline } from '../data/portfolio';
---

<Layout title="Dihgg | Diego Lopes" description="Portfolio de Diego Lopes, desenvolvedor web e de aplicacoes.">
	<main class="relative overflow-hidden">
		<div class="hero-glow hero-glow-left"></div>
		<div class="hero-glow hero-glow-right"></div>

		<section class="mx-auto max-w-6xl px-6 pb-16 pt-14 md:pt-20">
			<p class="font-mono text-xs uppercase tracking-[0.2em] text-black/60">{'{Dihgg}'}</p>
			<h1 class="mt-4 max-w-3xl text-5xl font-bold leading-[0.95] md:text-7xl">
				Diego Lopes
			</h1>
			<p class="mt-4 max-w-2xl text-lg text-black/75 md:text-xl">
				Cientista da computação, adoro aprender novas tecnologias e tenho interesses em: desenvolvimento WEB, Inteligência Artificial, Ciência de Dados, Internet das Coisas e desenvolvimento de jogos.
			</p>

			<div class="mt-8">
				<SocialLinks links={socialLinks} />
			</div>

			<div class="mt-10 flex flex-wrap gap-3">
				<Pill label="Entre em contato" variant="primary" href="#contato" />
				<Pill label="Ler blog" href="/blog/" />
			</div>
		</section>

		<section id="sobre" class="mx-auto max-w-6xl px-6 py-12">
			<h2 class="section-title">{'{Sobre}'}</h2>
			<p class="mt-4 max-w-3xl text-lg text-black/80">
				Com mais de uma década de experiência em desenvolvimento de software. Tenho experiência em empresas que incluem consultoria de desenvolvimento, aplicações web e desenvolvimento de jogos educacionais. Trabalhei com Frontend e Backend, com alguma experiência em: Javascript, Node, Angular, HTML, CSS, SQL, PHP, Python e Java.
			</p>
		</section>

		<section id="skills" class="mx-auto max-w-6xl px-6 py-12">
			<h2 class="section-title">{'{Skills}'}</h2>
			<div class="mt-6">
				<SkillList skills={skills} />
			</div>
		</section>

		<section id="trabalho" class="mx-auto max-w-6xl px-6 py-12">
			<h2 class="section-title">{'{Trabalho}'}</h2>
			<div class="mt-8 grid gap-4 md:grid-cols-2">
				{timeline.map((item) => (
					<article class="rounded-2xl border border-black/10 bg-white p-5 shadow-sm">
						<p class="font-mono text-xs uppercase tracking-wider text-black/50">{item.period}</p>
						<h3 class="mt-2 text-xl font-bold">{item.company}</h3>
						<p class="mt-1 text-sm font-semibold text-orange-700">{item.role}</p>
						<p class="mt-3 text-sm text-black/70">{item.summary}</p>
					</article>
				))}
			</div>
		</section>

		<section id="projetos" class="mx-auto max-w-6xl px-6 py-12">
			<h2 class="section-title">{'{Projetos}'}</h2>
			<div class="mt-8">
				<ProjectCards projects={projects} />
			</div>
		</section>

		<section id="contato" class="mx-auto max-w-6xl px-6 py-16">
			<h2 class="section-title">{'{Contato}'}</h2>
			<p class="mt-4 text-black/80">Envie um email para <a class="underline decoration-orange-500 decoration-2" href="mailto:dihgg@outlook.com">dihgg@outlook.com</a>.</p>
			<div class="mt-6">
				<SocialLinks links={socialLinks} />
			</div>
		</section>
	</main>
</Layout>
