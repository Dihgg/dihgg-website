---
import Layout from '@/layouts/Layout.astro';
import HomePage from '@/components/pages/HomePage.astro';
import { translations } from '@/data/translations';
import { SITE_URL } from '@/lib/constants';

const locale = 'pt-BR' as const;
const content = translations[locale];
---

<Layout
	title={content.homeTitle}
	description={content.homeDescription}
	lang={locale}
	alternates={[
		{ href: `${SITE_URL}/`, hreflang: 'pt-BR' },
		{ href: `${SITE_URL}/en/`, hreflang: 'en' }
	]}
	header={{
		brandHref: '/',
		blogHref: '/blog/',
		contactHref: '/#contato',
		blogLabel: content.headerBlogLabel,
		contactLabel: content.headerContactLabel
	}}
	footer={{
		currentLocale: locale,
		ptHref: '/',
		enHref: '/en/',
		switcherAriaLabel: content.switcherAriaLabel,
		madeWithLabel: content.madeWithLabel
	}}
>
	<HomePage locale={locale} />
</Layout>
