---
import ProjectCards from "@/components/ProjectCards";
import { translations } from "@/data/translations";
import { DEFAULT_LOCALE, EN_LOCALE } from "@/i18n/config";
import Layout from "@/layouts/Layout.astro";
import { getProjects } from "@/lib/portfolio";
import { getRelativeLocaleUrl } from "astro:i18n";

const { locale } = Astro.props;
const content = translations[DEFAULT_LOCALE];
const projects = await getProjects(locale);
---
<Layout
  title={content.projectsTitle}
  description={content.blogDescription}
  lang={locale}
  alternates={[
    { href: `${ getRelativeLocaleUrl(DEFAULT_LOCALE, 'projetos')}`, hreflang: 'pt-BR' },
    { href: `${ getRelativeLocaleUrl(EN_LOCALE, 'projects')}`, hreflang: 'en' }
  ]}
>
<h1>Projects page here</h1>
<pre>{JSON.stringify(projects)}</pre>
<pre>{JSON.stringify(locale)}</pre>
<ProjectCards projects={projects} ctaLabel={content.projectCta} />
</Layout>