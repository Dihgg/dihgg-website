---
import { render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedBlogPath, getLocalizedHomePath, siteContent } from '../../../data/siteContent';
import { getLocalizedBlogStaticPaths } from '../../../lib/blog';

export async function getStaticPaths() {
  return getLocalizedBlogStaticPaths('en', 'pt-BR');
}

const locale = 'en' as const;
const content = siteContent[locale];
const { post, alternatePost } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} | Blog Dihgg`}
  description={post.data.description}
  lang={locale}
  alternates={[
    { href: `https://dihgg.com${getLocalizedBlogPath('pt-BR', alternatePost?.slug)}`, hreflang: 'pt-BR' },
    { href: `https://dihgg.com/en/blog/${post.slug}/`, hreflang: 'en' }
  ]}
  footer={{
    currentLocale: locale,
    ptHref: getLocalizedBlogPath('pt-BR', alternatePost?.slug),
    enHref: getLocalizedBlogPath('en', post.slug),
    switcherAriaLabel: content.switcherAriaLabel,
    madeWithLabel: content.madeWithLabel
  }}
>
  <main class="mx-auto min-h-screen max-w-3xl px-6 py-16">
    <a href={getLocalizedBlogPath(locale)} class="font-mono text-sm text-black/60 hover:text-black">{content.backBlogLabel}</a>

    <h1 class="mt-5 text-4xl font-bold leading-tight">{post.data.title}</h1>
    <p class="mt-3 font-mono text-xs uppercase tracking-wide text-black/60">
      {post.data.date.toLocaleDateString(content.dateLocale)}
    </p>

    <article class="prose mt-10 max-w-none prose-a:text-orange-700 prose-headings:font-bold prose-p:text-black/80">
      <Content />
    </article>

    <p class="mt-10 text-sm text-black/50">
      <a href={getLocalizedHomePath(locale)} class="hover:text-black">{content.backHomeLabel}</a>
    </p>
  </main>
</Layout>