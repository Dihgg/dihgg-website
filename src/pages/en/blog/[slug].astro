---
import BlogPostPage from '../../../components/blog/BlogPostPage.astro';
import { getLocalizedBlogStaticPaths } from '../../../lib/blog';

export async function getStaticPaths() {
  return getLocalizedBlogStaticPaths('en', 'pt-BR');
}

const { post, alternatePost } = Astro.props;
---

<BlogPostPage locale="en" post={post} alternatePost={alternatePost} />