---
import BlogPostPage from '@/components/pages/BlogPostPage.astro';
import { getLocalizedBlogPostHrefs, getLocalizedBlogStaticPaths } from '@/lib/blog';
import { EN_LOCALE, getAlternateLocale } from '@/i18n/config';

export async function getStaticPaths() {
  return getLocalizedBlogStaticPaths(EN_LOCALE, getAlternateLocale(EN_LOCALE));
}

const { post, alternatePost } = Astro.props;
const { ptPostPath, enPostPath } = getLocalizedBlogPostHrefs(post, alternatePost);
---

<BlogPostPage locale={EN_LOCALE} post={post} ptPostPath={ptPostPath} enPostPath={enPostPath} />