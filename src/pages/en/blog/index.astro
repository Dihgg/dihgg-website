---
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedBlogPath, getLocalizedHomePath, siteContent } from '../../../data/siteContent';
import { getBlogPosts, getBlogPostPath } from '../../../lib/blog';

const locale = 'en' as const;
const content = siteContent[locale];

const posts = await getBlogPosts(locale);
---

<Layout
  title={content.blogPageTitle}
  description={content.blogDescription}
  lang={locale}
  alternates={[
    { href: 'https://dihgg.com/blog/', hreflang: 'pt-BR' },
    { href: 'https://dihgg.com/en/blog/', hreflang: 'en' }
  ]}
  header={{
    brandHref: '/en/',
    blogHref: '/en/blog/',
    contactHref: '/en/#contato',
    blogLabel: content.headerBlogLabel,
    contactLabel: content.headerContactLabel
  }}
  footer={{
    currentLocale: locale,
    ptHref: '/blog/',
    enHref: '/en/blog/',
    switcherAriaLabel: content.switcherAriaLabel,
    madeWithLabel: content.madeWithLabel
  }}
>
  <main class="mx-auto min-h-screen max-w-4xl px-6 py-16">
    <a href={getLocalizedHomePath(locale)} class="font-mono text-sm text-black/60 hover:text-black">{content.backHomeLabel}</a>

    <h1 class="mt-6 text-4xl font-bold">Blog</h1>
    <p class="mt-3 max-w-2xl text-black/70">{content.blogIntro}</p>

    {posts.length === 0 ? (
      <p class="mt-10 rounded-xl border border-blue-100 bg-white/80 p-5 text-slate-600">{content.noPostsLabel}</p>
    ) : (
      <ul class="mt-10 space-y-4">
        {posts.map((post) => (
          <li class="rounded-xl border border-black/10 bg-white p-5">
            <p class="font-mono text-xs text-black/60">{post.data.date.toLocaleDateString(content.dateLocale)}</p>
            <a class="mt-2 block text-2xl font-semibold hover:underline" href={getBlogPostPath(post)}>
              {post.data.title}
            </a>
            <p class="mt-2 text-black/70">{post.data.description}</p>
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>