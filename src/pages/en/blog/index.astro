---
import BlogIndexPage from '@/components/pages/BlogIndexPage.astro';
import { getBlogPageCount, getBlogPosts, getLocalizedBlogIndexHrefs, BLOG_POSTS_PER_PAGE } from '@/lib/blog';
import { EN_LOCALE, getAlternateLocale } from '@/i18n/config';

const locale = EN_LOCALE;
const alternateLocale = getAlternateLocale(locale);
const posts = await getBlogPosts(locale);
const alternatePosts = await getBlogPosts(alternateLocale);
const currentPage = 1;
const alternatePageCount = getBlogPageCount(alternatePosts.length);
const { ptHref, enHref } = getLocalizedBlogIndexHrefs(locale, currentPage, alternatePageCount);
---

<BlogIndexPage
	locale={locale}
	posts={posts.slice(0, BLOG_POSTS_PER_PAGE)}
	currentPage={currentPage}
	lastPage={getBlogPageCount(posts.length)}
	ptHref={ptHref}
	enHref={enHref}
/>