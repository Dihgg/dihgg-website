---
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import Layout from '@/layouts/Layout.astro';
import HomePage from '@/components/pages/HomePage.astro';
import { translations } from '@/data/translations';
import { DEFAULT_LOCALE, EN_LOCALE } from '@/i18n/config';

const locale = EN_LOCALE;
const content = translations[locale];
---

<Layout
  title={content.homeTitle}
  description={content.homeDescription}
  lang={locale}
  alternates={[
    { href: getAbsoluteLocaleUrl(DEFAULT_LOCALE), hreflang: DEFAULT_LOCALE },
    { href: getAbsoluteLocaleUrl(EN_LOCALE), hreflang: EN_LOCALE }
  ]}
>
  <HomePage locale={locale} />
</Layout>